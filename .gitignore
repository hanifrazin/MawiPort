# =============================================================================
# Picklement - Enterprise Java 21 Maven CLI Project
# =============================================================================
# Technologies: Maven, IntelliJ IDEA, FastExcel, Cucumber Gherkin, Picocli
# =============================================================================

# ===========================================================================
# Maven Build Outputs
# ===========================================================================

# Standard Maven build directory
target/

# Maven wrapper cache (optional - keep if using mvnw and want reproducibility)
# .mvn/wrapper/maven-wrapper.jar

# Dependency-reduced POM generated by Maven Shade/Assembly plugins
dependency-reduced-pom.xml

# Eclipse Maven plugin
.classpath
.project
.settings/

# ===========================================================================
# IntelliJ IDEA / JetBrains IDE Files
# ===========================================================================

# Project-specific settings
.idea/

# Module description files
*.iml

# IntelliJ workspace file (contains personal settings)
*.iws

# IntelliJ scratch files and local history
*.patch
*.orig
*.rej

# ===========================================================================
# OS Generated Files
# ===========================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux/Unix
*~
.?.swp
*.swo
*.swn

# ===========================================================================
# Generated Excel Reports (FastExcel)
# ===========================================================================

# Excel spreadsheets generated by FastExcel during tests/reports
*.xlsx
*.xls
*.xlsm
*.xlsb

# Reports directory for test outputs and Excel exports
reports/

# Cucumber HTML/JSON reports (if generated)
cucumber-results/
cucumber-report/

# ===========================================================================
# Logs and Runtime Data
# ===========================================================================

# Application logs
*.log
logs/
log/

# Temporary files
*.tmp
*.temp
tmp/

# ===========================================================================
# Environment and Secrets
# ===========================================================================

# Environment variables and secrets
.env
.env.local
.env.*.local

# Exclude default .env template (committers should maintain this)
!.env.example

# Keystores and certificates (should not be committed)
*.jks
*.keystore
*.p12
*.pfx

# ===========================================================================
# Cucumber Gherkin Specific
# ===========================================================================

# Generated step definition stubs (if any)
src/test/generated/

# ===========================================================================
# IDE and Editor Backup Files
# ===========================================================================

# Vim swap files
*~

# VS Code
.vscode/

# Any *.class files not in target/ (safety net)
**/*.class

# ===========================================================================
# Compiled Artifacts and Dependencies
# ===========================================================================

# JAR files (excluding packaged jar if needed for verification)
**/*.jar
